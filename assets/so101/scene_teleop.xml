<mujoco model="so101 teleop scene">
  <include file="so101_new_calib.xml"/>

  <statistic center="0.15 0 0.15" extent="0.5" meansize="0.05"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <global azimuth="160" elevation="-20"/>
  </visual>

  <asset>
    <texture name="grid" type="2d" builtin="checker" rgb1=".2 .3 .4" rgb2=".1 0.15 0.2" width="512" height="512"
      mark="cross" markrgb=".8 .8 .8"/>
    <material name="grid" texture="grid" texrepeat="1 1" texuniform="true"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" directional="true"/>
    <geom name="floor" size="0.5 0.5 0.01" type="plane" material="grid"/>

    <!-- Mocap target for XR right controller visualization -->
    <body name="right_target" pos="0.2 0 0.2" quat="1 0 0 0" mocap="true">
      <!-- X-axis arrow shaft (red) -->
      <geom name="right_target_x_shaft" type="cylinder" size="0.003 0.03" pos="0.03 0 0" zaxis="1 0 0" rgba="1 0 0 1" contype="0" conaffinity="0" group="1"/>
      <!-- Y-axis arrow shaft (green) -->
      <geom name="right_target_y_shaft" type="cylinder" size="0.003 0.03" pos="0 0.03 0" zaxis="0 1 0" rgba="0 1 0 1" contype="0" conaffinity="0" group="1"/>
      <!-- Z-axis arrow shaft (blue) -->
      <geom name="right_target_z_shaft" type="cylinder" size="0.003 0.03" pos="0 0 0.03" zaxis="0 0 1" rgba="0 0 1 1" contype="0" conaffinity="0" group="1"/>
      <site type="sphere" size="0.005" rgba="0 0 1 1" group="1"/>
    </body>

    <!-- World frame axes -->
    <geom name="world_x_shaft" type="cylinder" size="0.005 0.05" pos="0.05 0 0.0" zaxis="1 0 0" rgba="1 0 0 1" contype="0" conaffinity="0" group="1"/>
    <geom name="world_y_shaft" type="cylinder" size="0.005 0.05" pos="0 0.05 0.0" zaxis="0 1 0" rgba="0 1 0 1" contype="0" conaffinity="0" group="1"/>
    <geom name="world_z_shaft" type="cylinder" size="0.005 0.1" pos="0 0 0.1" zaxis="0 0 1" rgba="0 0 1 1" contype="0" conaffinity="0" group="1"/>
  </worldbody>
</mujoco>
